{
  "uid": "rootcause-ai-tokens",
  "title": "RootCause AI / Tokens",
  "tags": ["rootcause", "ai"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat", "title": "Tokens ultimo run", "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "rootcause_last_run_tokens", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "stat", "title": "Tokens / hora (todos los modelos)", "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(rate(rootcause_tokens_total[1h])) * 3600", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "stat", "title": "Invocaciones agente (acum.)", "id": 3,
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "colorMode": "none", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "rootcause_agent_invocations_total", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "stat", "title": "Exito vs fallo agente (acum.)", "id": 4,
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [ { "matcher": { "id": "byName", "options": "Fallos" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }, { "matcher": { "id": "byName", "options": "Exitos" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] } ] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "rootcause_agent_success_total", "legendFormat": "Exitos", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } },
        { "refId": "B", "expr": "rootcause_agent_failure_total", "legendFormat": "Fallos", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } }
      ]
    },
    {
      "type": "timeseries", "title": "Tokens/hora por modelo", "id": 5,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (model) (rate(rootcause_tokens_total[1h])) * 3600", "legendFormat": "{{model}}", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "piechart", "title": "Tokens totales por modelo", "id": 6,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "pieType": "donut", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum by (model) (rootcause_tokens_total)", "legendFormat": "{{model}}", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "Tokens por tipo (prompt vs response)", "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (kind) (rate(rootcause_tokens_total[1h])) * 3600", "legendFormat": "{{kind}}", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "Llamadas a agente y acciones de emergencia (por hora)", "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 50 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (success) (increase(rootcause_model_calls_total[1h]))", "legendFormat": "calls success={{success}}", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } },
        { "refId": "B", "expr": "increase(rootcause_emergency_actions_total[1h])", "legendFormat": "emergency actions", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } }
      ]
    }
  ]
}
