{
  "uid": "rootcause-temps",
  "title": "RootCause Host / Temperaturas",
  "tags": ["rootcause", "temps"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Host",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
        "query": { "query": "label_values(node_uname_info, instance)", "refId": "A" },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "sort": 1,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "stat", "title": "CPU (max)", "id": 1,
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "celsius", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "max by (instance) (node_hwmon_temp_celsius{instance=~\"$instance\",chip=~\".*(coretemp|k10temp|zenpower|cpu).*\"})", "legendFormat": "{{instance}}", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "stat", "title": "GPU (max)", "id": 2,
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "celsius", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "orange", "value": 83 }, { "color": "red", "value": 90 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "max by (instance) (nvidia_smi_temperature_gpu{instance=~\"$instance\"})", "legendFormat": "{{instance}}", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "stat", "title": "Sistema (max otros sensores)", "id": 3,
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "celsius", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "max by (instance) (node_hwmon_temp_celsius{instance=~\"$instance\",chip!~\".*(coretemp|k10temp|zenpower|cpu).*\"})", "legendFormat": "{{instance}}", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "Temperaturas del sistema (hwmon)", "id": 4,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "celsius", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "node_hwmon_temp_celsius{instance=~\"$instance\"}", "legendFormat": "{{instance}} · {{chip}}/{{sensor}}", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "Temperatura GPU (NVIDIA)", "id": 5,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "celsius", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "nvidia_smi_temperature_gpu{instance=~\"$instance\"}", "legendFormat": "{{instance}} · GPU {{uuid}}", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    }
  ]
}
