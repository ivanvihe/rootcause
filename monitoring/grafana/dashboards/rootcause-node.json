{
  "uid": "rootcause-node",
  "title": "RootCause Host / Sistema",
  "tags": ["rootcause", "node"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Host",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
        "query": { "query": "label_values(node_uname_info, instance)", "refId": "A" },
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "stat", "title": "CPU", "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 0, "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",instance=\"$instance\"}[5m])) * 100)", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "stat", "title": "Memoria", "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 0, "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "100 * (1 - node_memory_MemAvailable_bytes{instance=\"$instance\"} / node_memory_MemTotal_bytes{instance=\"$instance\"})", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "stat", "title": "Disco /", "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 0, "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 90 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "100 - (node_filesystem_avail_bytes{instance=\"$instance\",mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"} * 100 / node_filesystem_size_bytes{instance=\"$instance\",mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"})", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "stat", "title": "Uptime", "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "node_time_seconds{instance=\"$instance\"} - node_boot_time_seconds{instance=\"$instance\"}", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "Uso de CPU (%)", "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "100 - (avg by (mode) (rate(node_cpu_seconds_total{mode=\"idle\",instance=\"$instance\"}[5m])) * 100)", "legendFormat": "CPU", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "Memoria usada (bytes)", "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "none" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "node_memory_MemTotal_bytes{instance=\"$instance\"} - node_memory_MemAvailable_bytes{instance=\"$instance\"}", "legendFormat": "Usada", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } },
        { "refId": "B", "expr": "node_memory_MemTotal_bytes{instance=\"$instance\"}", "legendFormat": "Total", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } }
      ]
    },
    {
      "type": "timeseries", "title": "Uso de disco por montaje (%)", "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "100 - (node_filesystem_avail_bytes{instance=\"$instance\",fstype!~\"tmpfs|overlay|squashfs|ramfs\"} * 100 / node_filesystem_size_bytes{instance=\"$instance\",fstype!~\"tmpfs|overlay|squashfs|ramfs\"})", "legendFormat": "{{mountpoint}}", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "Red (bits/s)", "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "rate(node_network_receive_bytes_total{instance=\"$instance\",device!~\"lo|veth.*|docker.*|br-.*|virbr.*\"}[5m]) * 8", "legendFormat": "{{device}} rx", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } },
        { "refId": "B", "expr": "rate(node_network_transmit_bytes_total{instance=\"$instance\",device!~\"lo|veth.*|docker.*|br-.*|virbr.*\"}[5m]) * 8", "legendFormat": "{{device}} tx", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } }
      ]
    },
    {
      "type": "timeseries", "title": "Load average", "id": 9,
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "node_load1{instance=\"$instance\"}", "legendFormat": "load1", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } },
        { "refId": "B", "expr": "node_load5{instance=\"$instance\"}", "legendFormat": "load5", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } },
        { "refId": "C", "expr": "node_load15{instance=\"$instance\"}", "legendFormat": "load15", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } }
      ]
    },
    {
      "type": "timeseries", "title": "Estabilidad de red — packet loss y hops", "id": 10,
      "description": "Sondeo de red (mtr a 8.8.8.8 y al router) — misma fuente que el check internet_stability. No depende de $instance: mide la línea de Internet de la workstation.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 12, "axisLabel": "packet loss %" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*hops.*" }, "properties": [
            { "id": "unit", "value": "short" },
            { "id": "custom.axisPlacement", "value": "right" },
            { "id": "custom.axisLabel", "value": "hops" },
            { "id": "custom.fillOpacity", "value": 0 },
            { "id": "custom.lineWidth", "value": 2 }
          ] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "rootcause_ping_loss_percent", "legendFormat": "{{probe}} loss", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } },
        { "refId": "B", "expr": "rootcause_ping_hops", "legendFormat": "{{probe}} hops", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } }
      ]
    },
    {
      "type": "timeseries", "title": "Latencia de ping (Internet 8.8.8.8 / router)", "id": 11,
      "description": "Latencia RTT del mismo sondeo mtr. 'media' es la línea base móvil (EWMA) contra la que el check internet_stability compara para detectar subidas anómalas.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 8, "axisLabel": "RTT (ms)" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*media.*" }, "properties": [
            { "id": "custom.lineStyle", "value": { "dash": [6, 6], "fill": "dash" } },
            { "id": "custom.fillOpacity", "value": 0 }
          ] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "rootcause_ping_rtt_avg_ms", "legendFormat": "{{probe}} avg", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } },
        { "refId": "B", "expr": "rootcause_ping_rtt_worst_ms", "legendFormat": "{{probe}} worst", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } },
        { "refId": "C", "expr": "rootcause_ping_rtt_baseline_ms", "legendFormat": "{{probe}} media", "datasource": { "type": "prometheus", "uid": "rootcause-prometheus" } }
      ]
    }
  ]
}
