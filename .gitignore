__pycache__/
*.pyc

# SQLite store: config, secrets and runtime state — never commit it.
rootcause.db
rootcause.db-wal
rootcause.db-shm

# Legacy JSON config (imported into rootcause.db on first run; kept for rollback).
checks.json
checks.bak-*.json
.claude/

rootcause.log
rootcause_state.json
rootcause_status.json
rootcause_history.json
rootcause-web.log
.rootcause_notify_id
rootcause_ui.log
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/keystore.properties
android/keystore/
*.jks
rootcause_probe_cache.json
*.log.*

# Runtime-generated data (regenerated by the checker, not source)
rootcause_agent_calls.json
rootcause_metrics_counters.json
rootcause_problems.json
rootcause_ping_stats.json

# Firebase project config (contains app API key + project id) — provide locally
android/app/google-services.json
