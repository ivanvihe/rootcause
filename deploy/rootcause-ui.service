[Unit]
Description=RootCause mobile/web API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ivan
WorkingDirectory=/opt/rootcause
ExecStart=/usr/bin/python3 /opt/rootcause/rootcause_checker.py --serve
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
